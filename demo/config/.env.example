# Glass Box Protocol Demo - Environment Configuration

# =============================================================================
# CryptoPanic API (News Source)
# =============================================================================
# Get your free API key at: https://cryptopanic.com/developers/api/
# Free Tier: 100 requests/day
CRYPTOPANIC_API_TOKEN=your_cryptopanic_token_here

# =============================================================================
# CoinGecko API (Price Source)
# =============================================================================
# Free tier does not require API key (5-15 calls/minute)
# Pro tier (optional): https://www.coingecko.com/en/api/pricing
# COINGECKO_API_KEY=your_coingecko_pro_key_here

# =============================================================================
# SUI Testnet Configuration
# =============================================================================
# SUI Testnet RPC
SUI_TESTNET_RPC=https://fullnode.testnet.sui.io:443

# Agent wallet addresses (will be generated on first setup)
# SUI_AGENT_A_ADDRESS=0x...
# SUI_AGENT_B_ADDRESS=0x...
# SUI_AGENT_C_ADDRESS=0x...

# Agent private keys (keep secure! testnet only)
# SUI_AGENT_A_PRIVATE_KEY=
# SUI_AGENT_B_PRIVATE_KEY=
# SUI_AGENT_C_PRIVATE_KEY=

# =============================================================================
# Walrus DA Configuration
# =============================================================================
# Walrus testnet configuration
WALRUS_CONTEXT=testnet
WALRUS_EPOCHS=10

# Walrus wallet address (for DA storage)
# WALRUS_WALLET_ADDRESS=0x...

# =============================================================================
# Application Configuration
# =============================================================================
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache duration for price data (seconds)
PRICE_CACHE_DURATION=60

# Rate limiting
COINGECKO_REQUEST_INTERVAL=4.0  # seconds between requests (15/min)
CRYPTOPANIC_DAILY_LIMIT=100     # requests per day

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite database paths (relative to demo/ directory)
NEWS_DB_PATH=data/news.db
PREDICTIONS_DB_PATH=data/predictions.db
PORTFOLIO_DB_PATH=data/portfolio.db

# =============================================================================
# Output Directories
# =============================================================================
TRACES_DIR=output/traces
SIGNALS_DIR=output/signals
LOGS_DIR=output/logs
REPORTS_DIR=output/reports
